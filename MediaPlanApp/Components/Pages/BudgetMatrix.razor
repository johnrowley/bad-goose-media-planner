@page "/budget-matrix"
@inject IWebHostEnvironment Env
@using System.Text.Json
@using System.Net

<PageTitle>Budget Matrix</PageTitle>

<h1>Budget Matrix</h1>
<p class="text-muted mb-4">Select your audience age group and campaign budget to see recommended channel allocations.</p>

@if (matrix is null)
{
    <p>Loading data...</p>
}
else
{
    <div class="bm-layout">
        <div class="bm-main">

            <div class="d-flex gap-4 flex-wrap mb-4">
                <div>
                    <label class="form-label fw-semibold">Age Segment</label><br />
                    <TelerikDropDownList Data="@matrix.AgeSegments"
                                         @bind-Value="selectedAgeKey"
                                         TextField="@nameof(Segment.Label)"
                                         ValueField="@nameof(Segment.Key)"
                                         DefaultText="— Select age group —"
                                         Width="240px" />
                </div>
                <div>
                    <label class="form-label fw-semibold">Budget Band</label><br />
                    <TelerikDropDownList Data="@matrix.BudgetBands"
                                         @bind-Value="selectedBudgetKey"
                                         TextField="@nameof(Segment.Label)"
                                         ValueField="@nameof(Segment.Key)"
                                         DefaultText="— Select budget —"
                                         Width="240px" />
                </div>
            </div>

            @if (Recommendation is not null)
            {
                @if (!Recommendation.Recommended)
                {
                    <div class="alert alert-warning mt-3" style="max-width: 520px;">
                        <strong>Not Recommended</strong><br />
                        @Recommendation.Message
                    </div>
                }
                else
                {
                    <h5 class="mb-3">Recommended Channel Allocations</h5>

                    <table class="table table-hover" style="max-width: 480px;">
                        <thead class="table-light">
                            <tr>
                                <th>Channel</th>
                                <th class="text-end">Allocation</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alloc in Recommendation.Allocations)
                            {
                                <tr>
                                    <td>@alloc.Channel</td>
                                    <td class="text-end">@alloc.Percent%</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold @(Recommendation.TotalPercent != 100 ? "table-warning" : "")">
                                <td>Total</td>
                                <td class="text-end">@Recommendation.TotalPercent%</td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="mt-4" style="max-width: 480px;">
                        <ApexChart TItem="Allocation"
                                   Title="Channel Allocation"
                                   Options="@chartOptions">
                            <ApexPointSeries TItem="Allocation"
                                             Items="@Recommendation.Allocations"
                                             SeriesType="SeriesType.Pie"
                                             XValue="@(a => a.Channel)"
                                             YValue="@(a => a.Percent)" />
                        </ApexChart>
                    </div>

                    @if (Recommendation.Warnings.Any())
                    {
                        <div class="mt-2" style="max-width: 640px;">
                            @foreach (var warning in Recommendation.Warnings)
                            {
                                <p class="text-warning mb-1">&#9888; @warning</p>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Recommendation.Message))
                    {
                        <p class="text-muted mt-2 fst-italic">@Recommendation.Message</p>
                    }

                    <h5 class="mt-4 mb-3">Channel Details</h5>
                    <table class="table table-bordered" style="max-width: 640px;">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 160px;">Channel</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alloc in Recommendation.Allocations)
                            {
                                <tr>
                                    <td class="fw-semibold">@alloc.Channel</td>
                                    <td class="text-muted">@(ChannelDescriptions.GetValueOrDefault(alloc.ChannelKey, string.Empty))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (!string.IsNullOrEmpty(selectedAgeKey) && !string.IsNullOrEmpty(selectedBudgetKey))
            {
                <p class="text-muted">No recommendation found for this combination.</p>
            }

        </div>

        <div class="bm-json-panel">
            <div class="json-card">
                <div class="json-card-header">
                    <span class="json-card-title">JSON Source</span>
                    <span class="json-card-badge">@JsonPanelLabel</span>
                </div>
                <pre class="json-body">@HighlightedJson</pre>
            </div>
        </div>

    </div>
}

<style>
    .bm-layout {
        display: flex;
        gap: 2rem;
        align-items: flex-start;
    }

    .bm-main {
        flex: 1;
        min-width: 0;
    }

    .bm-json-panel {
        width: 400px;
        flex-shrink: 0;
        position: sticky;
        top: 1.5rem;
    }

    .json-card {
        background: #1e1e2e;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .json-card-header {
        background: #313244;
        padding: 0.65rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .json-card-title {
        color: #cdd6f4;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.03em;
    }

    .json-card-badge {
        background: #45475a;
        color: #a6adc8;
        font-size: 0.7rem;
        padding: 0.15rem 0.55rem;
        border-radius: 20px;
        font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
    }

    .json-body {
        margin: 0;
        padding: 1rem 1.1rem;
        font-size: 0.76rem;
        line-height: 1.6;
        color: #cdd6f4;
        font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
        overflow-x: auto;
        max-height: 82vh;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: #45475a #1e1e2e;
    }

    .json-key   { color: #89b4fa; }
    .json-str   { color: #a6e3a1; }
    .json-num   { color: #fab387; }
    .json-bool  { color: #f5c2e7; }
    .json-null  { color: #f5c2e7; }
    .json-punct { color: #6c7086; }
</style>

@code {
    private MatrixData? matrix;
    private string selectedAgeKey = string.Empty;
    private string selectedBudgetKey = string.Empty;

    private ApexChartOptions<Allocation> chartOptions = new()
    {
        Chart = new Chart { Height = 340 },
        Legend = new Legend { Position = LegendPosition.Bottom },
        DataLabels = new DataLabels
        {
            Formatter = "function(val) { return val.toFixed(0) + '%' }"
        },
        Tooltip = new Tooltip
        {
            Y = new TooltipY { Formatter = "function(val) { return val + '%' }" }
        }
    };

    private RecommendationEntry? Recommendation =>
        matrix is null || string.IsNullOrEmpty(selectedAgeKey) || string.IsNullOrEmpty(selectedBudgetKey)
            ? null
            : matrix.Recommendations.FirstOrDefault(r =>
                r.AudienceSegmentKey == selectedAgeKey && r.BudgetBandKey == selectedBudgetKey);

    private Dictionary<string, string> ChannelDescriptions =>
        matrix?.Channels.ToDictionary(c => c.Key, c => c.Description) ?? [];

    private string JsonPanelLabel => Recommendation is not null ? "recommendation" : "channels";

    private MarkupString HighlightedJson
    {
        get
        {
            object data = Recommendation is not null
                ? (object)Recommendation
                : matrix!.Channels;
            var raw = JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true });
            return TokenizeJson(raw);
        }
    }

    private static MarkupString TokenizeJson(string json)
    {
        var sb = new System.Text.StringBuilder(json.Length * 2);
        int i = 0;
        while (i < json.Length)
        {
            char ch = json[i];

            if (ch == '"')
            {
                // Scan to closing quote, respecting escape sequences
                int end = i + 1;
                while (end < json.Length)
                {
                    if (json[end] == '\\') { end += 2; continue; }
                    if (json[end] == '"') break;
                    end++;
                }
                string token = json.Substring(i, end - i + 1);

                // Peek past whitespace to see if a colon follows (= object key)
                int peek = end + 1;
                while (peek < json.Length && json[peek] == ' ') peek++;
                bool isKey = peek < json.Length && json[peek] == ':';

                string cls = isKey ? "json-key" : "json-str";
                sb.Append($"<span class=\"{cls}\">{WebUtility.HtmlEncode(token)}</span>");
                i = end + 1;
            }
            else if (ch == '-' || char.IsDigit(ch))
            {
                int end = i;
                while (end < json.Length && (char.IsDigit(json[end]) || json[end] == '.' || json[end] == '-' || json[end] == 'e' || json[end] == 'E' || json[end] == '+'))
                    end++;
                sb.Append($"<span class=\"json-num\">{json.Substring(i, end - i)}</span>");
                i = end;
            }
            else if (json.Length - i >= 4 && json.Substring(i, 4) == "true")
            {
                sb.Append("<span class=\"json-bool\">true</span>");
                i += 4;
            }
            else if (json.Length - i >= 5 && json.Substring(i, 5) == "false")
            {
                sb.Append("<span class=\"json-bool\">false</span>");
                i += 5;
            }
            else if (json.Length - i >= 4 && json.Substring(i, 4) == "null")
            {
                sb.Append("<span class=\"json-null\">null</span>");
                i += 4;
            }
            else if (ch == '{' || ch == '}' || ch == '[' || ch == ']' || ch == ':' || ch == ',')
            {
                sb.Append($"<span class=\"json-punct\">{ch}</span>");
                i++;
            }
            else
            {
                // Whitespace and anything else — output as-is (no encoding needed)
                sb.Append(ch);
                i++;
            }
        }
        return new MarkupString(sb.ToString());
    }

    protected override async Task OnInitializedAsync()
    {
        var path = Path.Combine(Env.ContentRootPath, "data", "media_channel_budget_matrix.json");
        await using var stream = File.OpenRead(path);
        matrix = await JsonSerializer.DeserializeAsync<MatrixData>(stream,
            new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    }

    private class MatrixData
    {
        public List<Segment> AgeSegments { get; set; } = [];
        public List<Segment> BudgetBands { get; set; } = [];
        public List<Channel> Channels { get; set; } = [];
        public List<RecommendationEntry> Recommendations { get; set; } = [];
    }

    private class Channel
    {
        public string Key { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }

    private class Segment
    {
        public string Key { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
    }

    private class RecommendationEntry
    {
        public string AudienceSegmentKey { get; set; } = string.Empty;
        public string BudgetBandKey { get; set; } = string.Empty;
        public bool Recommended { get; set; }
        public string? Message { get; set; }
        public List<Allocation> Allocations { get; set; } = [];
        public int TotalPercent { get; set; }
        public List<string> Warnings { get; set; } = [];
    }

    private class Allocation
    {
        public string Channel { get; set; } = string.Empty;
        public string ChannelKey { get; set; } = string.Empty;
        public int Percent { get; set; }
    }
}
