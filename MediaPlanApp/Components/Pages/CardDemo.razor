@page "/card-demo"

<PageTitle>Media Plan</PageTitle>

<h1>Media Plan</h1>

<ChannelCards Channels="@CardItems" />

<h2 class="mt-5 mb-3">Budget Distribution</h2>

<TelerikChart Height="420px">
    <ChartTitle Text="Monthly Budget by Channel" />
    <ChartLegend Position="ChartLegendPosition.Right" />
    <ChartSeriesItems>
        <ChartSeries Type="ChartSeriesType.Pie"
                     Data="@ChartData"
                     Field="@nameof(ChartPoint.Value)"
                     CategoryField="@nameof(ChartPoint.Label)">
            <ChartSeriesLabels Visible="true"
                               Format="{0:C0}"
                               Position="ChartSeriesLabelsPosition.OutsideEnd" />
        </ChartSeries>
    </ChartSeriesItems>
</TelerikChart>

@code {
    private record MediaChannel(string Name, string Category, string Description, decimal Budget);
    private record ChartPoint(string Label, double Value);

    private List<MediaChannel> channels =
    [
        new("RTE One",          "Television",    "Prime-time national TV reach across all demographics.",               45000m),
        new("Today FM",         "Radio",         "High-frequency breakfast and drive-time slots.",                      18500m),
        new("Irish Times",      "Print / Digital","Full-page and digital display in Ireland's paper of record.",        22000m),
        new("YouTube Pre-roll", "Digital Video", "Skippable 15–30 second spots targeting 25–44 age group.",            12000m),
        new("Meta Ads",         "Social Media",  "Carousel and story placements across Facebook and Instagram.",         9500m),
        new("Outdoor / OOH",    "Out of Home",   "48-sheet and 6-sheet panels in Dublin city and suburbs.",            31000m),
    ];

    private IEnumerable<ChannelCardItem> CardItems =>
        channels.Select(c => new ChannelCardItem(c.Name, c.Category, c.Budget, c.Description));

    private IEnumerable<ChartPoint> ChartData =>
        channels.Select(c => new ChartPoint(c.Name, (double)c.Budget));
}
