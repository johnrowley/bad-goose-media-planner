                "Public sector", "Community / non-profit", "Not sure",
            ]),
            new("age_group", 6, "What age group best describes the main audience?",
            [
                "Under 18", "18–24", "25–34", "35–44", "45–54", "55–64", "65+",
                "Broad adult audience", "Family / household audience",
                "No specific age group",
            ]),
        ]),

        new("Profile", [
            new("gender", 7, "What gender profile best describes the audience?",
            [
                "All genders equally", "Mostly female", "Mostly male",
                "Skews female but includes all", "Skews male but includes all",
                "Not relevant",
            ]),
            new("life_stage", 8, "What life stage best describes the audience?",
            [
                "Students", "Young professionals", "Singles",
                "Couples without children", "New parents",
                "Parents with young children", "Parents with teenagers",
                "Established families", "First-time buyers", "Homeowners",
                "Renters", "Empty nesters", "Retirees", "Business owners",
                "Senior professionals", "Not life-stage specific",
            ]),
            new("income", 9, "What income or spending profile best describes them?",
            [
                "Budget-conscious", "Value-seeking", "Mainstream / mass market",
