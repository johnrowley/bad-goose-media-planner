@page "/survey1"
@rendermode InteractiveServer

<PageTitle>Media Plan Survey</PageTitle>

<style>
    .step-panel {
        animation: fadeSlide 0.3s ease-in-out;
    }
    @@keyframes fadeSlide {
        from { opacity: 0; transform: translateX(18px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        position: relative;
    }
    .step-indicator::before {
        content: '';
        position: absolute;
        top: 16px;
        left: 0;
        right: 0;
        height: 2px;
        background: #dee2e6;
        z-index: 0;
    }
    .step-bubble {
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 1;
        flex: 1;
    }
    .step-bubble .circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #dee2e6;
        color: #6c757d;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.85rem;
        transition: background 0.3s, color 0.3s;
    }
    .step-bubble.active .circle  { background: #0d6efd; color: #fff; }
    .step-bubble.done .circle    { background: #198754; color: #fff; }
    .step-bubble .label {
        font-size: 0.7rem;
        margin-top: 4px;
        color: #6c757d;
        text-align: center;
    }
    .step-bubble.active .label { color: #0d6efd; font-weight: 600; }
    .step-bubble.done .label   { color: #198754; }
</style>

<h1>Media Plan Survey</h1>
<p class="text-muted mb-4">Answer the questions below to receive a personalised media plan recommendation.</p>

@if (submitted)
{
    <div class="card border-success">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Your Responses</h5>
        </div>
        <div class="card-body">
            @foreach (var group in Groups)
            {
                <h6 class="text-muted mt-3">@group.Name</h6>
                <dl class="row">
                    @foreach (var q in group.Questions)
                    {
                        var answer = responses[q.Id];
                        if (!string.IsNullOrEmpty(answer))
                        {
                            <dt class="col-sm-6">@q.Text</dt>
                            <dd class="col-sm-6">@answer</dd>
                        }
                    }
                </dl>
            }
            <button class="btn btn-outline-secondary mt-2" @onclick="Reset">Start Again</button>
        </div>
    </div>
}
else
{
    @* Step indicator *@
    <div class="step-indicator">
        @for (int i = 0; i < Groups.Length; i++)
        {
            var idx = i;
            var state = idx < currentStep ? "done" : idx == currentStep ? "active" : "";
            <div class="step-bubble @state">
                <div class="circle">
                    @if (idx < currentStep)
                    { <span>&#10003;</span> }
                    else
                    { <span>@(idx + 1)</span> }
                </div>
                <span class="label">@Groups[idx].Name</span>
            </div>
        }
    </div>

    @* Progress bar *@
    <div class="progress mb-4" style="height: 6px;">
        <div class="progress-bar bg-primary" style="width: @ProgressPercent%;" role="progressbar"></div>
    </div>

    @* Current step questions *@
    <div class="step-panel" @key="currentStep">
        <h5 class="mb-3">@CurrentGroup.Name</h5>

        @foreach (var q in CurrentGroup.Questions)
        {
            <div class="mb-4">
                <label class="form-label fw-semibold">@q.Number. @q.Text</label>
                <select class="form-select" @bind="responses[q.Id]">
                    <option value="">— Select an option —</option>
                    @foreach (var opt in q.Options)
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
            </div>
        }
    </div>

    @* Navigation *@
    <div class="d-flex justify-content-between mt-4">
        <button class="btn btn-outline-secondary" @onclick="Back" disabled="@(currentStep == 0)">
            &larr; Back
        </button>

        @if (currentStep < Groups.Length - 1)
        {
            <button class="btn btn-primary" @onclick="Next">
                Next &rarr;
            </button>
        }
        else
        {
            <button class="btn btn-success" @onclick="Submit">
                Submit
            </button>
        }
    </div>

    <p class="text-muted small mt-3">Step @(currentStep + 1) of @Groups.Length</p>
}

@code {
    private record Question(string Id, int Number, string Text, string[] Options);
    private record Group(string Name, Question[] Questions);

    private static readonly Group[] Groups =
