            [
                "No physical location", "One location", "2–5 locations",
                "6–20 locations", "20+ locations", "Franchise / dealer network",
                "Pop-up or temporary location", "Event venue", "Retail stockists",
                "Not sure",
            ]),
            new("motivation", 12, "What is the main customer motivation?",
            [
                "Save money", "Save time", "Convenience", "Quality",
                "Trust / reliability", "Expertise", "Health / wellbeing",
                "Status / prestige", "Entertainment", "Family / security",
                "Local support", "Sustainability", "Business growth",
                "Compliance / risk reduction", "Career progression", "Not sure",
            ]),
        ]),

        new("Budget", [
            new("barrier", 13, "What is the main barrier to purchase?",
            [
                "Price", "Lack of awareness", "Lack of trust", "Too complicated",
                "No urgency", "Competitor loyalty", "Location / access",
                "Time required", "Need approval from others", "Product availability",
                "Fear of switching", "Not sure",
            ]),
            new("first_party_data", 14, "What first-party data is available?",
            [
                "Customer email list", "CRM database", "Past purchasers",
                "Website visitors", "Cart abandoners", "App users",
                "Loyalty programme", "Previous leads / enquiries",
                "Store visitors", "Event attendees", "None", "Not sure",
            ]),
            new("budget", 15, "What is the approximate media budget?",
            [
                "Under €1,000", "€1,000–€5,000", "€5,000–€10,000",
                "€10,000–€25,000", "€25,000–€50,000", "€50,000–€100,000",
                "€100,000+", "Not confirmed yet",
            ]),
        ]),
    ];

    private static readonly Question[] AllQuestions =
        Groups.SelectMany(g => g.Questions).ToArray();

    private Dictionary<string, string> responses =
        Groups.SelectMany(g => g.Questions).ToDictionary(q => q.Id, _ => "");

    private int currentStep;
    private bool submitted;

    private Group CurrentGroup => Groups[currentStep];
    private int ProgressPercent => (currentStep * 100) / Groups.Length;

    private void Next() { if (currentStep < Groups.Length - 1) currentStep++; }
    private void Back() { if (currentStep > 0) currentStep--; }
    private void Submit() => submitted = true;

    private void Reset()
    {
        responses = Groups.SelectMany(g => g.Questions).ToDictionary(q => q.Id, _ => "");
        currentStep = 0;
        submitted = false;
    }
}
