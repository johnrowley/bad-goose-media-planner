                "Health / wellness product", "Food / drink", "Retail / e-commerce",
                "Property / home improvement", "Automotive", "Travel / leisure",
                "Education / training", "Entertainment / event",
                "B2B product or service", "Recruitment / employer brand",
                "Public information campaign", "Other",
            ]),
        ]),

        new("Audience", [
            new("audience", 4, "Who is the primary audience?",
            [
                "New customers", "Existing customers", "Lapsed customers",
                "Competitor customers", "Website visitors", "Previous enquirers / leads",
                "High-value customers", "Local residents", "Tourists / visitors",
                "Parents", "Students", "Homeowners", "Renters",
                "Business decision-makers", "Employees / job seekers",
