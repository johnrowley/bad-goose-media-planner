@page "/survey"
@rendermode InteractiveServer

<PageTitle>Media Plan Survey</PageTitle>

<h1>Media Plan Survey</h1>
<p class="text-muted">Answer the questions below to receive a personalised media plan recommendation.</p>

@if (submitted)
{
    <div class="card mt-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Your Responses</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                @foreach (var q in Questions)
                {
                    var answer = responses[q.Id];
                    if (!string.IsNullOrEmpty(answer))
                    {
                        <dt class="col-sm-6">@q.Text</dt>
                        <dd class="col-sm-6">@answer</dd>
                    }
                }
            </dl>
            <button class="btn btn-outline-secondary" @onclick="Reset">Start Again</button>
        </div>
    </div>
}
else
{
    <EditForm Model="responses" OnValidSubmit="Submit" class="mt-4">
        @foreach (var q in Questions)
        {
            <div class="mb-4">
                <label class="form-label fw-semibold">@q.Number. @q.Text</label>
                <select class="form-select" @bind="responses[q.Id]">
                    <option value="">— Select an option —</option>
                    @foreach (var opt in q.Options)
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
            </div>
        }

        <button type="submit" class="btn btn-primary mt-2">Submit</button>
    </EditForm>
}

