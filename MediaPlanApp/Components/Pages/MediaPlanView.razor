@page "/media-plan-view"
@inject MediaPlanStateService PlanState
@inject NavigationManager Nav

<PageTitle>@(PlanState.HasPlan ? PlanState.PlanName : "Media Plan View")</PageTitle>

@if (!PlanState.HasPlan)
{
    <div class="mt-4">
        <h2>No plan saved yet</h2>
        <p class="text-muted">Build a plan first and it will appear here.</p>
        <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                       OnClick="@(() => Nav.NavigateTo("/create-media-plan"))">
            Create a Plan
        </TelerikButton>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-1">
        <div>
            <h1>@PlanState.PlanName</h1>
            @if (!string.IsNullOrEmpty(PlanState.Audience))
            {
                <p class="text-muted mb-0">Audience: <strong>@PlanState.Audience</strong></p>
            }
        </div>
        <TelerikButton OnClick="@(() => Nav.NavigateTo("/create-media-plan"))">
            Edit Plan
        </TelerikButton>
    </div>

    <ChannelCards Channels="@PlanState.Channels" />

    <h2 class="mt-5 mb-3">Budget Distribution</h2>

    <TelerikChart Height="420px">
        <ChartTitle Text="Budget by Channel" />
        <ChartLegend Position="ChartLegendPosition.Right" />
        <ChartSeriesItems>
            <ChartSeries Type="ChartSeriesType.Pie"
                         Data="@ChartData"
                         Field="@nameof(ChartPoint.Value)"
                         CategoryField="@nameof(ChartPoint.Label)">
                <ChartSeriesLabels Visible="true"
                                   Format="€{0:N0}"
                                   Position="ChartSeriesLabelsPosition.OutsideEnd" />
            </ChartSeries>
        </ChartSeriesItems>
    </TelerikChart>

    <p class="mt-3 fw-bold">
        Total Budget: €@PlanState.Channels.Sum(c => c.Budget).ToString("N0")
    </p>
}

@code {
    private record ChartPoint(string Label, double Value);

    private IEnumerable<ChartPoint> ChartData =>
        PlanState.Channels.Select(c => new ChartPoint(c.Name, (double)c.Budget));
}
