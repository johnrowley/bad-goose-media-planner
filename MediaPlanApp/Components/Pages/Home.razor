@page "/"
@inject IConfiguration Config

<PageTitle>Media Plan</PageTitle>

<h1>Media Plan</h1>

<p>Select a client from the sidebar to view their report.</p>

<ul>
    @foreach (var client in clients)
    {
        <li><a href="report/@client.Slug">@client.Name</a></li>
    }
</ul>

@code {
    private List<ClientConfig> clients = [];

    protected override void OnInitialized()
    {
        clients = Config.GetSection("Clients").Get<List<ClientConfig>>() ?? [];
    }
}
