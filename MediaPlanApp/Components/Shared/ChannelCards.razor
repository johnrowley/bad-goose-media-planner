<div class="channel-card-grid">
    @foreach (var channel in Channels)
    {
        <TelerikCard Width="280px">
            <CardHeader>
                <CardTitle>@channel.Name</CardTitle>
                <CardSubTitle>@channel.Category</CardSubTitle>
            </CardHeader>
            @if (!string.IsNullOrEmpty(channel.Description))
            {
                <CardBody>
                    <p>@channel.Description</p>
                </CardBody>
            }
            <CardSeparator />
            <CardFooter>
                <span class="channel-card-metric">
                    Monthly Budget: <strong>€@channel.Budget.ToString("N0")</strong>
                </span>
            </CardFooter>
        </TelerikCard>
    }
</div>

<style>
    .channel-card-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 1rem 0;
    }
    .channel-card-metric {
        font-size: 0.9rem;
        color: #555;
    }
</style>

@code {
    [Parameter] public IEnumerable<ChannelCardItem> Channels { get; set; } = [];
}
