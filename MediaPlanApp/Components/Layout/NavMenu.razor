@inject IConfiguration Config

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">MediaPlanApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

     
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="survey">
                <span class="bi bi-clipboard2-check-fill-nav-menu" aria-hidden="true"></span> Survey
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="survey1">
                <span class="bi bi-clipboard2-check-fill-nav-menu" aria-hidden="true"></span> Survey (Stepped)
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="card-demo">
                <span class="bi bi-card-text-nav-menu" aria-hidden="true"></span> Card Demo
            </NavLink>
        </div>

           <div class="nav-item px-3">
            <NavLink class="nav-link" href="create-media-plan">
                <span class="bi bi-file-earmark-plus-nav-menu" aria-hidden="true"></span> Create Plan
            </NavLink>
        </div>


        <div class="nav-item px-3">
            <NavLink class="nav-link" href="spreadsheet">
                <span class="bi bi-card-text-nav-menu" aria-hidden="true"></span> Spreadsheet Demo
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="spread-demo">
                <span class="bi bi-file-earmark-spreadsheet-nav-menu" aria-hidden="true"></span> Spread Demo
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="spread-xml">
                <span class="bi bi-file-earmark-spreadsheet-nav-menu" aria-hidden="true"></span> Spread XML
            </NavLink>
        </div>

        @foreach (var client in clients)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"report/{client.Slug}")">
                    <span class="bi bi-bar-chart-fill-nav-menu" aria-hidden="true"></span> @client.Name
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private List<ClientConfig> clients = [];

    protected override void OnInitialized()
    {
        clients = Config.GetSection("Clients").Get<List<ClientConfig>>() ?? [];
    }
}
